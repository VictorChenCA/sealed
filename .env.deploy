# Env vars passed to EigenCompute deploy. NO secrets here — MNEMONIC is
# auto-injected by EigenCompute KMS and sealed to the enclave.
APP_PORT=3000
MODEL_PATH=/app/models/qwen2.5-3b-instruct-q4_k_m.gguf
# COMMIT_SHA_PUBLIC and IMAGE_TAG_PUBLIC are set at build time by ecloud's
# pipeline via --build-arg in the Dockerfile. Do NOT set them at runtime
# or they'll override the build-baked values.
RUBRIC_VERSION_PUBLIC=v1.0
DEFAULT_CIRCLE_TARGET_N=5

# TLS via Caddy inside the enclave. nip.io wildcard DNS resolves
# 34-178-145-214.nip.io -> 34.178.145.214 (this app's public IP).
DOMAIN=34-178-145-214.nip.io
ACME_STAGING=false
ENABLE_CADDY_LOGS=true
